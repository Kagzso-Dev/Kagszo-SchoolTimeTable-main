# ============================================================
# Copy this file to .env and fill in your values
# For cloud hosting: set these as server environment variables
# ============================================================

# ── Option A: individual fields (Railway / Clever Cloud / Aiven) ──
DB_HOST=your-mysql-host.example.com
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=timetable_db
DB_PORT=3306

# ── Option B: full connection string (takes priority over A) ──
# DATABASE_URL=mysql://user:password@host:3306/timetable_db

# ── Cloud SSL (set to true for Railway / PlanetScale / Aiven) ──
# DB_SSL=true

# ── Email (optional — enables leave approval notifications) ──
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASSWORD=your_16char_app_password
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
